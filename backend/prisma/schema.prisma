// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Core Business & Auth
// -----------------------------------------------------------------------------

model Business {
  id        String   @id @default(uuid())
  name      String
  gstin     String?
  address   String?
  logoUrl   String?
  currency  String   @default("INR")
  timezone  String   @default("Asia/Kolkata")
  pincode   String?
  phone     String?
  email     String?
  taxConfig Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  parties          Party[]
  products         Product[]
  warehouses       Warehouse[]
  invoices         Invoice[]
  purchaseOrders   PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
  payments         Payment[]
  stockEntries     StockEntry[]
  accounts         Account[]
  journalEntries   JournalEntry[]
  expenses         Expense[]
  taxGroups        TaxGroup[]
  quotations       Quotation[]
  partyLedger      PartyLedger[]
}

model User {
  id           String    @id @default(uuid())
  businessId   String
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(OWNER)
  lastActive   DateTime?
  twoFaSecret  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  ADMIN
  ACCOUNTANT
  SALES
  INVENTORY_MANAGER
  VIEWER
}

// -----------------------------------------------------------------------------
// Parties (Customers & Suppliers)
// -----------------------------------------------------------------------------

model Party {
  id             String    @id @default(uuid())
  businessId     String
  name           String
  type           PartyType
  gstin          String?
  pan            String?
  email          String?
  phone          String?
  address        String?
  creditLimit    Decimal?  @db.Decimal(12, 2)
  paymentTerms   String?
  openingBalance Decimal   @default(0) @db.Decimal(12, 2)
  outstanding    Decimal   @default(0) @db.Decimal(12, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices         Invoice[]
  purchaseOrders   PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
  payments         Payment[]
  journalLines     JournalLine[]
  quotations       Quotation[]
  ledger           PartyLedger[]
}

model PartyLedger {
  id         String          @id @default(uuid())
  businessId String
  partyId    String
  date       DateTime        @default(now())
  type       LedgerEntryType
  amount     Decimal         @db.Decimal(12, 2)
  balance    Decimal         @db.Decimal(12, 2) // Running balance after this entry
  reference  String? // Invoice #, Payment ID, etc.
  notes      String?
  createdAt  DateTime        @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party    Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
}

enum LedgerEntryType {
  INVOICE
  PAYMENT
  REFUND
  ADJUSTMENT
  OPENING_BALANCE
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

// -----------------------------------------------------------------------------
// Products & Inventory
// -----------------------------------------------------------------------------

model Product {
  id             String   @id @default(uuid())
  businessId     String
  name           String
  description    String?
  sku            String?
  hsnSac         String?
  categoryId     String?
  unit           String   @default("PCS")
  purchasePrice  Decimal  @default(0) @db.Decimal(12, 2)
  salePrice      Decimal  @default(0) @db.Decimal(12, 2)
  taxGroupId     String?
  trackInventory Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  taxGroup      TaxGroup?      @relation(fields: [taxGroupId], references: [id])
  invoiceItems  InvoiceItem[]
  purchaseItems PurchaseItem[]
  stockEntries  StockEntry[]
}

model Warehouse {
  id         String  @id @default(uuid())
  businessId String
  name       String
  location   String?
  isDefault  Boolean @default(false)

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stockEntries StockEntry[]
}

model StockEntry {
  id          String         @id @default(uuid())
  businessId  String
  productId   String
  warehouseId String
  type        StockEntryType
  qty         Decimal        @db.Decimal(10, 3)
  batch       String?
  expiry      DateTime?
  cost        Decimal?       @db.Decimal(12, 2)
  reference   String?
  notes       String?
  date        DateTime       @default(now())
  createdAt   DateTime       @default(now())

  business  Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
}

enum StockEntryType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

// -----------------------------------------------------------------------------
// Tax & Pricing
// -----------------------------------------------------------------------------

model TaxGroup {
  id         String   @id @default(uuid())
  businessId String
  name       String
  components Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]
}

// -----------------------------------------------------------------------------
// Sales (Quotations, Invoices)
// -----------------------------------------------------------------------------

model Quotation {
  id         String          @id @default(uuid())
  businessId String
  partyId    String
  number     String
  date       DateTime        @default(now())
  validUntil DateTime?
  status     QuotationStatus @default(DRAFT)
  subtotal   Decimal         @db.Decimal(12, 2)
  taxAmount  Decimal         @db.Decimal(12, 2)
  discount   Decimal         @default(0) @db.Decimal(12, 2)
  total      Decimal         @db.Decimal(12, 2)
  notes      String?
  currency   String          @default("INR")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  items QuotationItem[]

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party    Party    @relation(fields: [partyId], references: [id])
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  INVOICED
}

model QuotationItem {
  id          String  @id @default(uuid())
  quotationId String
  productId   String?
  description String
  qty         Decimal @db.Decimal(10, 3)
  unit        String
  unitPrice   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  taxAmount   Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Invoice {
  id         String        @id @default(uuid())
  businessId String
  partyId    String
  type       InvoiceType
  number     String
  date       DateTime
  dueDate    DateTime?
  status     InvoiceStatus @default(DRAFT)
  subtotal   Decimal       @db.Decimal(12, 2)
  taxAmount  Decimal       @db.Decimal(12, 2)
  discount   Decimal       @default(0) @db.Decimal(12, 2)
  total      Decimal       @db.Decimal(12, 2)
  notes      String?
  currency   String        @default("INR")
  irn        String?
  qrCode     String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party    Party         @relation(fields: [partyId], references: [id])
  items    InvoiceItem[]
  payments Payment[]
}

enum InvoiceType {
  TAX_INVOICE
  PROFORMA
  CREDIT_NOTE
  DEBIT_NOTE
  DELIVERY_CHALLAN
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  qty         Decimal @db.Decimal(10, 3)
  unit        String
  unitPrice   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  taxAmount   Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

// -----------------------------------------------------------------------------
// Purchases (POs, Bills)
// -----------------------------------------------------------------------------

model PurchaseOrder {
  id         String   @id @default(uuid())
  businessId String
  partyId    String
  number     String
  date       DateTime
  status     POStatus @default(DRAFT)
  subtotal   Decimal  @db.Decimal(12, 2)
  taxAmount  Decimal  @db.Decimal(12, 2)
  total      Decimal  @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party            Party             @relation(fields: [partyId], references: [id])
  items            PurchaseItem[]
  purchaseInvoices PurchaseInvoice[]
}

enum POStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

model PurchaseInvoice {
  id         String                @id @default(uuid())
  businessId String
  partyId    String
  poId       String?
  number     String
  date       DateTime
  dueDate    DateTime?
  status     PurchaseInvoiceStatus @default(DRAFT)
  subtotal   Decimal               @db.Decimal(12, 2)
  taxAmount  Decimal               @db.Decimal(12, 2)
  discount   Decimal               @default(0) @db.Decimal(12, 2)
  total      Decimal               @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party         Party          @relation(fields: [partyId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [poId], references: [id])
  items         PurchaseItem[]
}

enum PurchaseInvoiceStatus {
  DRAFT
  PENDING
  RECEIVED
  PARTIAL
  PAID
  OVERDUE
}

model PurchaseItem {
  id                String  @id @default(uuid())
  purchaseOrderId   String?
  purchaseInvoiceId String?
  productId         String?
  description       String
  qty               Decimal @db.Decimal(10, 3)
  unit              String
  unitPrice         Decimal @db.Decimal(12, 2)
  discount          Decimal @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal @default(0) @db.Decimal(12, 2)
  total             Decimal @db.Decimal(12, 2)

  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseInvoice PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  product         Product?         @relation(fields: [productId], references: [id])
}

// -----------------------------------------------------------------------------
// Payments
// -----------------------------------------------------------------------------

model Payment {
  id           String        @id @default(uuid())
  businessId   String
  invoiceId    String?
  partyId      String
  amount       Decimal       @db.Decimal(12, 2)
  date         DateTime      @default(now())
  mode         PaymentMode
  reference    String?
  status       PaymentStatus @default(SUCCESS)
  gatewayTxnId String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])
  party    Party    @relation(fields: [partyId], references: [id])
}

enum PaymentMode {
  CASH
  CHEQUE
  UPI
  NEFT_RTGS
  CARD
  CREDIT
  ADVANCE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// -----------------------------------------------------------------------------
// Accounting
// -----------------------------------------------------------------------------

model Account {
  id             String      @id @default(uuid())
  businessId     String
  name           String
  type           AccountType
  parentId       String?
  code           String?
  openingBalance Decimal     @default(0) @db.Decimal(12, 2)
  description    String?

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountHierarchy")
  journalLines JournalLine[]
  expenses     Expense[]
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model JournalEntry {
  id         String   @id @default(uuid())
  businessId String
  date       DateTime @default(now())
  narration  String
  reference  String?
  createdBy  String?
  createdAt  DateTime @default(now())

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lines    JournalLine[]
}

model JournalLine {
  id         String  @id @default(uuid())
  journalId  String
  accountId  String
  debit      Decimal @default(0) @db.Decimal(12, 2)
  credit     Decimal @default(0) @db.Decimal(12, 2)
  partyId    String?
  invoiceRef String?

  journal JournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])
  party   Party?       @relation(fields: [partyId], references: [id])
}

model Expense {
  id          String      @id @default(uuid())
  businessId  String
  categoryId  String?
  amount      Decimal     @db.Decimal(12, 2)
  date        DateTime    @default(now())
  paymentMode PaymentMode
  accountId   String?
  notes       String?
  receiptUrl  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  account  Account? @relation(fields: [accountId], references: [id])
}
